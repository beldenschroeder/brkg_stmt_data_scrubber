# -----------------------------------------------------------------------------
# brkg_stmt_data_scrubber — environment configuration template
#
# Copy this file to ".env" in the project root and adjust values as needed.
# The ".env" file is gitignored and will never be committed.
# -----------------------------------------------------------------------------

# ----- Input / output -----

# Path to the input PDF statement (absolute or relative to the project root).
# Can be overridden on the CLI: `brkg_scrubber path/to/other.pdf`
INPUT_PDF=./input/statement.pdf

# Directory where the two output CSV files will be written.
OUTPUT_DIR=./output

# ----- Output filenames (without extension) -----
BROKERAGE_CSV_NAME=brokerage_income
RETIREMENT_BROKERAGE_CSV_NAME=retirement_brokerage_income

# ----- Behavior toggles -----

# Include BUY/SELL trades from the "TRADE AND INVESTMENT ACTIVITY" section
# in the output (true/false). Per the spec, these are emitted as separate
# rows with Account="N/A" and Description="<TICKER> (buy|sell)".
INCLUDE_TRADES=true

# Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
